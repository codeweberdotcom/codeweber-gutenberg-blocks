{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "codeweber-blocks/video",
  "version": "1.0.0",
  "title": "Video",
  "category": "codeweber-gutenberg-elements",
  "icon": "format-video",
  "description": "Display video (HTML5, Vimeo, YouTube, VK, Rutube) with poster and lightbox",
  "keywords": [
    "video",
    "vimeo",
    "youtube",
    "vk",
    "rutube",
    "lightbox"
  ],
  "textdomain": "codeweber-gutenberg-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "supports": {
    "html": false,
    "customClassName": true
  },
  "attributes": {
    "borderRadius": {
      "type": "string",
      "default": ""
    },
    "videoType": {
      "type": "string",
      "default": "html5"
    },
    "videoUrl": {
      "type": "string",
      "default": ""
    },
    "videoVimeoId": {
      "type": "string",
      "default": ""
    },
    "videoYoutubeId": {
      "type": "string",
      "default": ""
    },
    "videoVkId": {
      "type": "string",
      "default": ""
    },
    "videoRutubeId": {
      "type": "string",
      "default": ""
    },
    "videoEmbed": {
      "type": "string",
      "default": ""
    },
    "videoPoster": {
      "type": "object",
      "default": {
        "id": 0,
        "url": "",
        "alt": ""
      }
    },
    "videoPosterSize": {
      "type": "string",
      "default": "full"
    },
    "videoAutoplay": {
      "type": "boolean",
      "default": false
    },
    "videoLoop": {
      "type": "boolean",
      "default": false
    },
    "videoMuted": {
      "type": "boolean",
      "default": false
    },
    "videoControls": {
      "type": "boolean",
      "default": true
    },
    "showPlayIcon": {
      "type": "boolean",
      "default": true
    },
    "videoLightbox": {
      "type": "boolean",
      "default": false
    },
    "lightboxUniqueId": {
      "type": "string",
      "default": ""
    },
    "LinkType": {
      "type": "string",
      "default": ""
    },
    "LinkUrl": {
      "type": "string",
      "default": ""
    },
    "PostId": {
      "type": "string",
      "default": ""
    },
    "PostType": {
      "type": "string",
      "default": ""
    },
    "PageId": {
      "type": "string",
      "default": ""
    },
    "CF7ID": {
      "type": "string",
      "default": ""
    },
    "CodeweberFormID": {
      "type": "string",
      "default": ""
    },
    "ModalID": {
      "type": "string",
      "default": ""
    },
    "HtmlID": {
      "type": "string",
      "default": ""
    },
    "PhoneType": {
      "type": "string",
      "default": ""
    },
    "PhoneNumber": {
      "type": "string",
      "default": ""
    },
    "YoutubeID": {
      "type": "string",
      "default": ""
    },
    "VimeoID": {
      "type": "string",
      "default": ""
    },
    "RutubeID": {
      "type": "string",
      "default": ""
    },
    "DocumentID": {
      "type": "string",
      "default": ""
    },
    "DocumentAction": {
      "type": "string",
      "default": "download"
    },
    "VKID": {
      "type": "string",
      "default": ""
    },
    "DataGlightbox": {
      "type": "string",
      "default": ""
    },
    "DataGallery": {
      "type": "string",
      "default": ""
    },
    "DataBsToggle": {
      "type": "string",
      "default": ""
    },
    "DataBsTarget": {
      "type": "string",
      "default": ""
    },
    "DataValue": {
      "type": "string",
      "default": ""
    },
    "ArchiveId": {
      "type": "string",
      "default": ""
    },
    "ArchiveType": {
      "type": "string",
      "default": ""
    },
    "blockClass": {
      "type": "string",
      "default": ""
    },
    "blockId": {
      "type": "string",
      "default": ""
    },
    "blockData": {
      "type": "string",
      "default": ""
    }
  }
}