<?xml version="1.0" encoding="utf-8"?>
<!--
  Loco Translate configuration for Codeweber Gutenberg Blocks.
  Source strategy: PHP files + compiled JS in build/blocks/ (webpack output).
  Run `npm run i18n:update` after adding new translatable strings.
-->
<bundle name="Codeweber Gutenberg Blocks">

  <domain name="codeweber-gutenberg-blocks">
    <project name="Codeweber Gutenberg Blocks">

      <source>
        <file>plugin.php</file>
        <directory>inc</directory>
        <directory>settings</directory>
        <directory>build/blocks</directory>
        <exclude>
          <path>node_modules</path>
          <path>src</path>
          <path>vendor</path>
          <path>scripts</path>
        </exclude>
      </source>

      <target>
        <directory>languages</directory>
      </target>

      <!-- locked: Loco reads existing POT instead of re-scanning.
           POT is generated by `npm run i18n:update` (wp i18n make-pot + build/ JS). -->
      <template locked="true">
        <file>languages/codeweber-gutenberg-blocks.pot</file>
      </template>

    </project>
  </domain>

</bundle>
