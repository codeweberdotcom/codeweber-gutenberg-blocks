{
  "apiVersion": 3,
  "name": "codeweber-blocks/wc-filter-panel",
  "version": "0.2.0",
  "title": "WC Filter Panel",
  "category": "codeweber-gutenberg-elements",
  "icon": "filter",
  "description": "WooCommerce shop filter panel: price, attributes, categories, rating, stock. Integrates with shop PJAX navigation.",
  "keywords": ["filter", "shop", "woocommerce", "price", "attributes"],
  "supports": {
    "html": false,
    "customClassName": true,
    "anchor": true
  },
  "attributes": {
    "items": {
      "type": "array",
      "default": [
        {
          "id": "item-price",
          "type": "filter",
          "filterType": "price",
          "label": "Цена",
          "displayMode": "list",
          "queryType": "or",
          "taxonomy": "",
          "showCount": true
        }
      ]
    }
  },
  "textdomain": "codeweber-gutenberg-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
