{
	"apiVersion": 3,
	"name": "codeweber-blocks/tabs",
	"version": "0.2.0",
	"title": "Tabs",
	"category": "codeweber-gutenberg-elements",
	"icon": "admin-page",
	"description": "Bootstrap tabs with multiple items. Supports basic and pills styles with icons.",
	"keywords": [
		"tabs",
		"tab",
		"navigation",
		"nav"
	],
	"supports": {
		"html": false,
		"customClassName": true,
		"anchor": true
	},
	"providesContext": {
		"codeweber/tabsId": "tabsId",
		"codeweber/activeTabIndex": "activeTab"
	},
	"attributes": {
		"anchor": {
			"type": "string",
			"default": ""
		},
		"tabStyle": {
			"type": "string",
			"default": "basic"
		},
		"tabRounded": {
			"type": "string",
			"default": ""
		},
		"tabAlignment": {
			"type": "string",
			"default": "left"
		},
		"tabBackground": {
			"type": "boolean",
			"default": false
		},
		"tabsId": {
			"type": "string",
			"default": ""
		},
		"tabsClass": {
			"type": "string",
			"default": ""
		},
		"tabsData": {
			"type": "string",
			"default": ""
		},
		"items": {
			"type": "array",
			"default": []
		},
		"innerBlocksByTab": {
			"type": "object",
			"default": {}
		},
		"activeTab": {
			"type": "number",
			"default": 0
		}
	},
	"textdomain": "codeweber-gutenberg-blocks",
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
