<?xml version="1.0" encoding="utf-8"?>
<!--
  Loco Translate configuration for Codeweber Gutenberg Blocks.

  Source strategy: PHP files + compiled JS in build/blocks/
  wp i18n make-pot scans webpack output — strings are preserved as literals.
  Run `npm run i18n:update` after adding new translatable strings.
-->
<loco version="2">

  <meta>
    <name>Codeweber Gutenberg Blocks</name>
    <domain>codeweber-gutenberg-blocks</domain>
  </meta>

  <file type="po" id="default">
    <name>POT Template</name>
    <locale/>
    <domain>codeweber-gutenberg-blocks</domain>
    <path>languages/codeweber-gutenberg-blocks.pot</path>
    <!-- Scan PHP files and compiled JS blocks; skip sources and deps -->
    <source>plugin.php</source>
    <source>inc/**/*.php</source>
    <source>settings/**/*.php</source>
    <source>build/blocks/**/*.js</source>
    <exclude>node_modules/**</exclude>
    <exclude>src/**</exclude>
    <exclude>vendor/**</exclude>
    <exclude>scripts/**</exclude>
    <exclude>build/blocks/**/view.js</exclude>
  </file>

  <file type="po" id="ru_RU">
    <name>Russian</name>
    <locale>ru_RU</locale>
    <domain>codeweber-gutenberg-blocks</domain>
    <path>languages/codeweber-gutenberg-blocks-ru_RU.po</path>
  </file>

</loco>
