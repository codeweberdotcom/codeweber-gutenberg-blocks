{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "codeweber-blocks/openstreet-map",
  "version": "1.0.0",
  "title": "OpenStreet Map",
  "category": "codeweber-gutenberg-blocks",
  "icon": "location",
  "description": "Display OpenStreetMap with custom markers or CPT locations",
  "keywords": [
    "map",
    "openstreetmap",
    "osm",
    "leaflet",
    "markers",
    "locations"
  ],
  "supports": {
    "html": false,
    "customClassName": false
  },
  "textdomain": "codeweber-gutenberg-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.scss",
  "style": "file:./style.scss",
  "render": "file:./render.php",
  "attributes": {
    "dataSource": {
      "type": "string",
      "default": "custom"
    },
    "center": {
      "type": "object",
      "default": {
        "lat": 55.76,
        "lng": 37.64
      }
    },
    "zoom": {
      "type": "number",
      "default": 12
    },
    "height": {
      "type": "number",
      "default": 450
    },
    "tileLayer": {
      "type": "string",
      "default": "osm"
    },
    "borderRadius": {
      "type": "string",
      "default": ""
    },
    "enableScrollZoom": {
      "type": "boolean",
      "default": false
    },
    "enableDrag": {
      "type": "boolean",
      "default": true
    },
    "autoFitBounds": {
      "type": "boolean",
      "default": true
    },
    "clustering": {
      "type": "boolean",
      "default": false
    },
    "markerColor": {
      "type": "string",
      "default": "#0d6efd"
    },
    "markerType": {
      "type": "string",
      "default": "dot-label"
    },
    "customMarkers": {
      "type": "array",
      "default": []
    },
    "cptQuery": {
      "type": "object",
      "default": {
        "postType": "offices",
        "postsPerPage": -1,
        "orderBy": "title",
        "order": "asc",
        "latField": "_office_latitude",
        "lngField": "_office_longitude",
        "addressField": "_office_street",
        "phoneField": "_office_phone",
        "descriptionField": "_office_description"
      }
    },
    "popupFields": {
      "type": "object",
      "default": {
        "showTitle": true,
        "showAddress": true,
        "showPhone": true,
        "showDescription": false,
        "showLink": true,
        "showStaff": false
      }
    },
    "animationType": {
      "type": "string",
      "default": ""
    },
    "animationDuration": {
      "type": "number",
      "default": 700
    },
    "animationDelay": {
      "type": "number",
      "default": 0
    },
    "blockClass": {
      "type": "string",
      "default": ""
    },
    "blockId": {
      "type": "string",
      "default": ""
    },
    "blockData": {
      "type": "string",
      "default": ""
    }
  }
}